# PostgreSQL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio
POSTGRES_HOST=postgres

# Prisma — replace with real credentials; never commit .env
DATABASE_URL=postgresql://portfolio:changeme@postgres:5432/portfolio

# Backend
PORT=3000

# CORS — comma-separated list of allowed origins
ALLOW_ORIGIN=http://localhost:5173

# Google Gemini (for the portfolio chat feature — get key at aistudio.google.com)
GEMINI_API_KEY=

# Gmail SMTP (use an App Password, not your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Strapi CMS — separate database on the shared Postgres instance (see
# postgres/initdb.d), not the backend's Prisma-managed DATABASE_URL above
STRAPI_DATABASE_URL=postgresql://portfolio:changeme@postgres:5432/strapi
# Generate with: openssl rand -base64 32 (run twice, comma-separate, for APP_KEYS)
STRAPI_APP_KEYS=changeme-generate-two-random-strings,changeme-generate-two-random-strings
STRAPI_ADMIN_JWT_SECRET=changeme-use-a-long-random-string
STRAPI_API_TOKEN_SALT=changeme-use-a-long-random-string
STRAPI_TRANSFER_TOKEN_SALT=changeme-use-a-long-random-string
STRAPI_JWT_SECRET=changeme-use-a-long-random-string
STRAPI_ENCRYPTION_KEY=changeme-use-a-long-random-string
# API token for frontend-builder to read content — create it in the Strapi
# admin panel (Settings > API Tokens, "Read-only") after first login at /cms/admin
STRAPI_API_TOKEN=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Google Analytics 4
VITE_GA_ID=

# Public site URL (used for SEO canonical/OG tags)
VITE_SITE_URL=https://example.com
