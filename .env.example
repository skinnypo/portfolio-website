# PostgreSQL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio
POSTGRES_HOST=postgres

# Prisma — replace with real credentials; never commit .env
DATABASE_URL=postgresql://portfolio:changeme@postgres:5432/portfolio

# Backend
PORT=3000

# Auth — change JWT_SECRET and ADMIN_PASSWORD before deploying
JWT_SECRET=changeme-use-a-long-random-string
ADMIN_PASSWORD=changeme

# CORS — comma-separated list of allowed origins
ALLOW_ORIGIN=http://localhost:5173

# Google Gemini (for the portfolio chat feature — get key at aistudio.google.com)
GEMINI_API_KEY=

# Gmail SMTP (use an App Password, not your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Email address to receive admin OTP codes (defaults to GMAIL_USER if unset)
ADMIN_EMAIL=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Google Analytics 4
VITE_GA_ID=

# Public site URL (used for SEO canonical/OG tags)
VITE_SITE_URL=https://example.com
